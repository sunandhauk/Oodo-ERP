{
  "name": "odoo-erp-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend for the Mini ERP demand-to-delivery flow",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node --env-file=.env node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node --env-file=.env node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node --env-file=.env dist/main.js",
    "seed": "node --env-file=.env node_modules/ts-node/dist/bin.js src/scripts/seed-admin.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@supabase/supabase-js": "^2.53.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.13.1",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "eslint": "^9.33.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
